# ── Cohere ────────────────────────────────────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here
COHERE_EMBED_MODEL=embed-english-v3.0
COHERE_RERANK_MODEL=rerank-english-v3.0
COHERE_GENERATE_MODEL=command-r-plus

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # leave blank for local dev
QDRANT_COLLECTION=rag_documents

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Postgres (document metadata + audit) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace_with_at_least_32_byte_random_secret
JWT_ALGORITHM=HS256
JWT_AUDIENCE=rag-pipeline
JWT_ISSUER=rag-pipeline-auth

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO
API_RATE_LIMIT=60             # requests per minute per API key
MAX_CONTEXT_TOKENS=4096
RETRIEVAL_TOP_K=50
RERANK_TOP_N=10
HYBRID_ALPHA=0.5              # 0 = pure sparse, 1 = pure dense

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=rag-pipeline
